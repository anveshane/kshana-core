{
  "name": "Characters & Settings Phase - Individual File Creation",
  "description": "Tests that characters and settings are created individually with separate output files, not bundled together in a single file.",
  "promptPath": "video/workflow.md",
  "temperature": 0,
  "maxTokens": 1500,
  "systemPrompt": "You are a video generation orchestrator. You must process characters and settings ONE AT A TIME. Each character must be saved to its own file in the characters/ directory. Each setting must be saved to its own file in the settings/ directory. NEVER create a single file with all characters or settings bundled together.",
  "tools": [
    {
      "name": "Task",
      "description": "Dispatch a subagent to perform a task",
      "parameters": {
        "subagent_type": {
          "type": "string",
          "description": "Type of subagent: content-creator, image-generator, video-assembler"
        },
        "task": {
          "type": "string",
          "description": "The task description - should be for a SINGLE character or setting"
        },
        "content_type": {
          "type": "string",
          "description": "Type of content: character, setting"
        },
        "context_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Context references like $story"
        },
        "output_file": {
          "type": "string",
          "description": "Output file path - should be characters/<name>.md or settings/<name>.md"
        }
      }
    },
    {
      "name": "TodoWrite",
      "description": "Create or update the todo list",
      "parameters": {
        "merge": {
          "type": "boolean",
          "description": "Whether to merge with existing todos"
        },
        "todos": {
          "type": "array",
          "description": "Array of todo items"
        }
      }
    },
    {
      "name": "read_project",
      "description": "Read the current project state",
      "parameters": {}
    },
    {
      "name": "update_project",
      "description": "Update the project state",
      "parameters": {
        "action": { "type": "string" },
        "data": { "type": "object" }
      }
    }
  ],
  "cases": [
    {
      "name": "Should create individual character file with specific name",
      "context": {
        "project_id": "proj-123",
        "project_title": "Epic Fantasy",
        "current_phase": "characters_settings",
        "phase_display_name": "Character & Setting Descriptions",
        "loaded_contexts": "$story",
        "phase_instructions": "Create detailed character profile for Kira. Use Task with content_type='character' and output_file='characters/kira.md'. Process ONE character at a time.",
        "expensive_checkpoint": ""
      },
      "assertions": [
        { "type": "tool_called", "value": "Task" },
        { "type": "tool_arg_equals", "toolName": "Task", "argPath": "content_type", "value": "character" },
        { "type": "tool_arg_contains", "toolName": "Task", "argPath": "output_file", "value": "characters/" },
        { "type": "tool_arg_contains", "toolName": "Task", "argPath": "task", "value": "Kira" }
      ],
      "tags": ["character", "individual-file", "output-path"]
    },
    {
      "name": "Should create individual setting file with specific name",
      "context": {
        "project_id": "proj-123",
        "project_title": "Epic Fantasy",
        "current_phase": "characters_settings",
        "phase_display_name": "Character & Setting Descriptions",
        "loaded_contexts": "$story",
        "phase_instructions": "Create detailed setting description for the Ancient Forest. Use Task with content_type='setting' and output_file='settings/ancient_forest.md'. Process ONE setting at a time.",
        "expensive_checkpoint": ""
      },
      "assertions": [
        { "type": "tool_called", "value": "Task" },
        { "type": "tool_arg_equals", "toolName": "Task", "argPath": "content_type", "value": "setting" },
        { "type": "tool_arg_contains", "toolName": "Task", "argPath": "output_file", "value": "settings/" },
        { "type": "tool_arg_contains", "toolName": "Task", "argPath": "task", "value": "Ancient Forest" }
      ],
      "tags": ["setting", "individual-file", "output-path"]
    },
    {
      "name": "Character output_file should NOT be plans/characters.md",
      "context": {
        "project_id": "proj-123",
        "project_title": "Test Story",
        "current_phase": "characters_settings",
        "phase_display_name": "Character & Setting Descriptions",
        "loaded_contexts": "$story",
        "phase_instructions": "Create character profile for Daniel. Save to individual file characters/daniel.md. DO NOT use plans/characters.md.",
        "expensive_checkpoint": ""
      },
      "assertions": [
        { "type": "tool_called", "value": "Task" },
        { "type": "tool_arg_equals", "toolName": "Task", "argPath": "content_type", "value": "character" },
        { "type": "tool_arg_not_contains", "toolName": "Task", "argPath": "output_file", "value": "plans/characters" }
      ],
      "tags": ["character", "negative", "no-bundled-file"]
    },
    {
      "name": "Setting output_file should NOT be plans/settings.md",
      "context": {
        "project_id": "proj-123",
        "project_title": "Test Story",
        "current_phase": "characters_settings",
        "phase_display_name": "Character & Setting Descriptions",
        "loaded_contexts": "$story",
        "phase_instructions": "Create setting description for the Train Station. Save to individual file settings/train_station.md. DO NOT use plans/settings.md.",
        "expensive_checkpoint": ""
      },
      "assertions": [
        { "type": "tool_called", "value": "Task" },
        { "type": "tool_arg_equals", "toolName": "Task", "argPath": "content_type", "value": "setting" },
        { "type": "tool_arg_not_contains", "toolName": "Task", "argPath": "output_file", "value": "plans/settings" }
      ],
      "tags": ["setting", "negative", "no-bundled-file"]
    },
    {
      "name": "Task description should be for single character, not multiple",
      "context": {
        "project_id": "proj-123",
        "project_title": "Test Story",
        "current_phase": "characters_settings",
        "phase_display_name": "Character & Setting Descriptions",
        "loaded_contexts": "$story",
        "phase_instructions": "Create detailed character profile for Sarah. This is one character only. Do not extract or create multiple characters in this Task.",
        "expensive_checkpoint": ""
      },
      "assertions": [
        { "type": "tool_called", "value": "Task" },
        { "type": "tool_arg_contains", "toolName": "Task", "argPath": "task", "value": "Sarah" },
        { "type": "tool_arg_not_contains", "toolName": "Task", "argPath": "task", "value": "characters and settings" },
        { "type": "tool_arg_not_contains", "toolName": "Task", "argPath": "task", "value": "Extract all" }
      ],
      "tags": ["character", "single-item", "no-batch"]
    },
    {
      "name": "Should create TodoWrite with individual items before processing",
      "context": {
        "project_id": "proj-123",
        "project_title": "Fantasy Adventure",
        "current_phase": "characters_settings",
        "phase_display_name": "Character & Setting Descriptions",
        "loaded_contexts": "$story",
        "phase_instructions": "Story has characters: Alice, Bob, Charlie. Create a todo for each character, then process them one at a time. Start by creating the TodoWrite.",
        "expensive_checkpoint": ""
      },
      "assertions": [
        { "type": "tool_called", "value": "TodoWrite" },
        { "type": "tool_arg_equals", "toolName": "TodoWrite", "argPath": "merge", "value": false }
      ],
      "tags": ["todo", "planning", "individual-items"]
    },
    {
      "name": "Character file path should use lowercase name",
      "context": {
        "project_id": "proj-123",
        "project_title": "Test Story",
        "current_phase": "characters_settings",
        "phase_display_name": "Character & Setting Descriptions",
        "loaded_contexts": "$story",
        "phase_instructions": "Create character profile for Commander Rex. Save to characters/commander_rex.md or characters/rex.md (lowercase, underscores for spaces).",
        "expensive_checkpoint": ""
      },
      "assertions": [
        { "type": "tool_called", "value": "Task" },
        { "type": "tool_arg_contains", "toolName": "Task", "argPath": "output_file", "value": "characters/" },
        { "type": "tool_arg_matches", "toolName": "Task", "argPath": "output_file", "pattern": "^characters/[a-z_]+\\.md$" }
      ],
      "tags": ["character", "file-naming", "lowercase"]
    },
    {
      "name": "Should use $story as context_refs for character",
      "context": {
        "project_id": "proj-123",
        "project_title": "Test Story",
        "current_phase": "characters_settings",
        "phase_display_name": "Character & Setting Descriptions",
        "loaded_contexts": "$story, $plot, $original_input",
        "phase_instructions": "Create character profile for Elena using the story content. Use context_refs=['$story'].",
        "expensive_checkpoint": ""
      },
      "assertions": [
        { "type": "tool_called", "value": "Task" },
        { "type": "tool_arg_contains", "toolName": "Task", "argPath": "context_refs", "value": "$story" }
      ],
      "tags": ["character", "context-source", "story-source"]
    },
    {
      "name": "Should use $story as context_refs for setting",
      "context": {
        "project_id": "proj-123",
        "project_title": "Test Story",
        "current_phase": "characters_settings",
        "phase_display_name": "Character & Setting Descriptions",
        "loaded_contexts": "$story, $plot, $original_input",
        "phase_instructions": "Create setting description for the Castle using the story content. Use context_refs=['$story'].",
        "expensive_checkpoint": ""
      },
      "assertions": [
        { "type": "tool_called", "value": "Task" },
        { "type": "tool_arg_contains", "toolName": "Task", "argPath": "context_refs", "value": "$story" }
      ],
      "tags": ["setting", "context-source", "story-source"]
    },
    {
      "name": "Character file MUST use .md extension, NOT .json",
      "context": {
        "project_id": "proj-123",
        "project_title": "Test Story",
        "current_phase": "characters_settings",
        "phase_display_name": "Character & Setting Descriptions",
        "loaded_contexts": "$story",
        "phase_instructions": "Create character profile for Marcus. Save to characters/marcus.md. CRITICAL: Always use .md extension, NEVER .json.",
        "expensive_checkpoint": ""
      },
      "assertions": [
        { "type": "tool_called", "value": "Task" },
        { "type": "tool_arg_contains", "toolName": "Task", "argPath": "output_file", "value": ".md" },
        { "type": "tool_arg_not_contains", "toolName": "Task", "argPath": "output_file", "value": ".json" }
      ],
      "tags": ["character", "file-extension", "md-not-json"]
    },
    {
      "name": "Setting file MUST use .md extension, NOT .json",
      "context": {
        "project_id": "proj-123",
        "project_title": "Test Story",
        "current_phase": "characters_settings",
        "phase_display_name": "Character & Setting Descriptions",
        "loaded_contexts": "$story",
        "phase_instructions": "Create setting description for the Mountain Cave. Save to settings/mountain_cave.md. CRITICAL: Always use .md extension, NEVER .json.",
        "expensive_checkpoint": ""
      },
      "assertions": [
        { "type": "tool_called", "value": "Task" },
        { "type": "tool_arg_contains", "toolName": "Task", "argPath": "output_file", "value": ".md" },
        { "type": "tool_arg_not_contains", "toolName": "Task", "argPath": "output_file", "value": ".json" }
      ],
      "tags": ["setting", "file-extension", "md-not-json"]
    },
    {
      "name": "Character file should NOT use .json even without explicit instruction",
      "context": {
        "project_id": "proj-123",
        "project_title": "Test Story",
        "current_phase": "characters_settings",
        "phase_display_name": "Character & Setting Descriptions",
        "loaded_contexts": "$story",
        "phase_instructions": "Create character profile for Nina. Save to characters/ directory.",
        "expensive_checkpoint": ""
      },
      "assertions": [
        { "type": "tool_called", "value": "Task" },
        { "type": "tool_arg_contains", "toolName": "Task", "argPath": "output_file", "value": "characters/" },
        { "type": "tool_arg_not_contains", "toolName": "Task", "argPath": "output_file", "value": ".json" }
      ],
      "tags": ["character", "file-extension", "implicit-md"]
    },
    {
      "name": "Setting file should NOT use .json even without explicit instruction",
      "context": {
        "project_id": "proj-123",
        "project_title": "Test Story",
        "current_phase": "characters_settings",
        "phase_display_name": "Character & Setting Descriptions",
        "loaded_contexts": "$story",
        "phase_instructions": "Create setting description for the Harbor. Save to settings/ directory.",
        "expensive_checkpoint": ""
      },
      "assertions": [
        { "type": "tool_called", "value": "Task" },
        { "type": "tool_arg_contains", "toolName": "Task", "argPath": "output_file", "value": "settings/" },
        { "type": "tool_arg_not_contains", "toolName": "Task", "argPath": "output_file", "value": ".json" }
      ],
      "tags": ["setting", "file-extension", "implicit-md"]
    }
  ]
}
