{
  "name": "kshana-ink",
  "version": "0.1.0",
  "description": "Generic CLI agent framework with React Ink",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./core/llm": {
      "types": "./dist/core/llm/index.d.ts",
      "import": "./dist/core/llm/index.js"
    }
  },
  "bin": {
    "kshana-ink": "./dist/cli.js",
    "kshana-ink-server": "./dist/server/cli.js"
  },
  "scripts": {
    "start": "tsx src/index.tsx",
    "dev": "tsx watch src/index.tsx",
    "server": "tsx src/server/cli.ts",
    "server:dev": "tsx watch src/server/cli.ts",
    "test:client": "tsx src/server/testClient.ts",
    "build": "tsup && npm run copy-prompts",
    "copy-prompts": "node -e \"require('fs').cpSync('prompts', 'dist/prompts', {recursive: true, force: true})\"",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit && eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "keywords": [
    "cli",
    "react",
    "ink",
    "agent",
    "llm",
    "terminal"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/websocket": "^11.2.0",
    "dotenv": "^17.2.3",
    "eventemitter3": "^5.0.1",
    "fastify": "^5.6.2",
    "nanoid": "^5.1.5",
    "openai": "^4.72.0",
    "uuid": "^13.0.0",
    "zod": "^3.24.4"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "ink": "^5.2.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "ink": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.29",
    "@types/react": "^19.0.0",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.0",
    "@vitest/coverage-v8": "^3.2.3",
    "eslint": "^9.28.0",
    "ink": "^6.0.0",
    "ink-testing-library": "^4.0.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "react": "^19.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^3.2.3",
    "ws": "^8.18.0"
  }
}
