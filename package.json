{
  "name": "kshana-ink",
  "version": "0.1.0",
  "description": "Generic CLI agent framework with React Ink",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "kshana-ink": "./dist/index.js",
    "kshana-ink-server": "./dist/server/cli.js"
  },
  "scripts": {
    "start": "NODE_OPTIONS='--max-old-space-size=8192' tsx src/index.tsx",
    "fake": "NODE_OPTIONS='--max-old-space-size=8192' KSHANA_FAKE_MODE=1 tsx src/index.tsx",
    "dev": "NODE_OPTIONS='--max-old-space-size=8192' tsx watch src/index.tsx",
    "server": "NODE_OPTIONS='--max-old-space-size=8192' tsx src/server/cli.ts",
    "server:dev": "NODE_OPTIONS='--max-old-space-size=8192' tsx watch src/server/cli.ts",
    "test:client": "tsx src/server/testClient.ts",
    "build": "tsup",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:coverage": "vitest run --coverage",
    "eval": "tsx scripts/run-evals.ts --live",
    "eval:mock": "tsx scripts/run-evals.ts",
    "lint": "tsc --noEmit && eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "remotion:studio": "cd remotion-infographics && remotion studio src/index.tsx"
  },
  "keywords": [
    "cli",
    "react",
    "ink",
    "agent",
    "llm",
    "terminal"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.24.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sharp",
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/websocket": "^11.2.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.3",
    "eventemitter3": "^5.0.1",
    "fastify": "^5.6.2",
    "ink": "^5.2.0",
    "nanoid": "^5.1.5",
    "openai": "^4.72.0",
    "react": "^18.3.1",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.29",
    "@types/react": "^18.3.23",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.0",
    "@vitest/coverage-v8": "^3.2.3",
    "eslint": "^9.28.0",
    "ink-testing-library": "^4.0.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^3.2.3",
    "ws": "^8.18.0"
  }
}
