{
  "name": "kshana-ink",
  "version": "0.1.0",
  "description": "Generic CLI agent framework with React Ink",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./server": "./dist/server/index.cjs",
    "./server/cli": "./dist/server/cli.cjs",
    "./core/llm": {
      "types": "./dist/core/llm/index.d.cts",
      "default": "./dist/core/llm/index.cjs"
    },
    "./manager": {
      "types": "./dist/server/manager.d.cts",
      "default": "./dist/server/manager.cjs"
    },
    "./runners": {
      "types": "./dist/server/runners/index.d.cts",
      "default": "./dist/server/runners/index.cjs"
    },
    "./agent/pi": {
      "types": "./dist/agent/pi/index.d.cts",
      "default": "./dist/agent/pi/index.cjs"
    }
  },
  "files": [
    "dist",
    "prompts",
    "workflows",
    "README.md"
  ],
  "bin": {
    "kshana-ink": "./dist/index.js",
    "kshana-ink-server": "./dist/server/cli.cjs"
  },
  "scripts": {
    "start": "pnpm -C frontend run build && NODE_OPTIONS='--max-old-space-size=8192' tsx src/server/cli.ts",
    "dev": "pnpm -C frontend run build && NODE_OPTIONS='--max-old-space-size=8192' tsx watch src/server/cli.ts",
    "cli": "NODE_OPTIONS='--max-old-space-size=8192' tsx src/index.ts",
    "kill": "pkill -f 'tsx.*src/server/cli.ts' || true; pkill -f 'tsx.*src/index.ts' || true; echo 'All kshana processes killed'",
    "test:client": "tsx src/server/testClient.ts",
    "reset": "tsx scripts/reset-project.ts",
    "run-to": "tsx scripts/run-to.ts",
    "new": "tsx scripts/new-project.ts",
    "inspect": "tsx scripts/show-project.ts",
    "nodes": "tsx scripts/list-items.ts",
    "status": "tsx scripts/project-status.ts",
    "regen": "tsx scripts/regen-node.ts",
    "override": "tsx scripts/set-content.ts",
    "calibrate-vlm": "tsx scripts/calibrate-vlm.ts",
    "backfill-schema": "tsx scripts/backfill-project-schema.ts",
    "audit-fidelity": "tsx scripts/audit-fidelity.ts",
    "build": "pnpm -C frontend run build && tsup",
    "build:frontend": "pnpm -C frontend run build",
    "test:frontend": "pnpm -C frontend test",
    "test": "vitest run tests/unit/",
    "test:ci": "vitest run tests/unit/",
    "test:e2e": "vitest run tests/e2e/",
    "test:coverage": "vitest run --coverage",
    "eval": "tsx scripts/run-evals.ts --live",
    "eval:mock": "tsx scripts/run-evals.ts",
    "lint": "tsc --noEmit && eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "remotion:studio": "cd remotion-infographics && remotion studio src/index.tsx",
    "analytics:backfill:posthog": "tsx scripts/backfill-posthog-from-sqlite.ts",
    "stop": "tsx scripts/stop-executor.ts"
  },
  "keywords": [
    "cli",
    "agent",
    "llm",
    "terminal"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.24.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sharp",
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/websocket": "^11.2.0",
    "@mariozechner/pi-agent-core": "^0.70.6",
    "@mariozechner/pi-ai": "^0.70.6",
    "@mariozechner/pi-coding-agent": "^0.70.6",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.3",
    "eventemitter3": "^5.0.1",
    "fastify": "^5.6.2",
    "nanoid": "^5.1.5",
    "openai": "^4.72.0",
    "posthog-node": "^5.28.1",
    "react": "^18.3.1",
    "sharp": "^0.34.5",
    "typebox": "^1.1.34",
    "uuid": "^13.0.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.29",
    "@types/react": "^18.3.23",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.0",
    "@vitest/coverage-v8": "^3.2.3",
    "eslint": "^9.28.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^3.2.3",
    "ws": "^8.18.0"
  }
}
