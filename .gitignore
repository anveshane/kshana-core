.DS_Store
Thumbs.db
*.kshana/
# Testing
coverage/

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# Misc
*.tsbuildinfo

# Subprojects
prompt-optimizer/

# Project data
.kshana/

# Local outputs (generated images/videos)
outputs/
test-output/

# Claude Code local config (per-user) — ignore everything in .claude/
# EXCEPT skills/, which are project-local and ship with the repo so
# agents driving this codebase find them.
.claude/*
!.claude/skills

# Uploaded files
uploads/

# Workflow runs
workflows/runs/

# Per-user workflow manifests + JSONs. Each dev pins their own
# preferred workflows; not for git.
workflows/user/

# Packed release artifacts
*.tgz
