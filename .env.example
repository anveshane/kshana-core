# kshana-ink Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Choose your LLM provider: "gemini", "lmstudio", "openai", or "custom"
LLM_PROVIDER=lmstudio

# =============================================================================
# Gemini Configuration (only needed if LLM_PROVIDER=gemini)
# =============================================================================
# Get your API key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Gemini model to use (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# =============================================================================
# LM Studio Configuration (only needed if LLM_PROVIDER=lmstudio)
# =============================================================================
# LM Studio server URL (default: http://127.0.0.1:1234/v1)
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1

# Model name loaded in LM Studio (e.g., "qwen3", "llama-3.2", etc.)
LMSTUDIO_MODEL=qwen3

# API key for LM Studio (usually not needed for local setup)
LMSTUDIO_API_KEY=not-needed

# =============================================================================
# OpenAI Configuration (only needed if LLM_PROVIDER=openai)
# =============================================================================
# OpenAI API key
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI base URL (default: https://api.openai.com/v1)
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI model to use (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# =============================================================================
# Custom/Fallback Configuration (if LLM_PROVIDER is not set or set to "custom")
# =============================================================================
# Base URL for any OpenAI-compatible API
LLM_BASE_URL=http://127.0.0.1:1234/v1

# API key for authentication
LLM_API_KEY=not-needed

# Model name to use
LLM_MODEL=local-model

# =============================================================================
# Context Window Configuration
# =============================================================================
# Maximum context tokens for the LLM (adjust based on your model's capacity)
# - Local models (LM Studio): typically 4096-32768
# - OpenAI GPT-4: 128000
# - Gemini: 1000000+
# Default: 16000 (conservative for local models)
LLM_CONTEXT_TOKENS=16000

# =============================================================================
# ComfyUI Configuration (for image/video generation)
# =============================================================================
# ComfyUI server URL (default: http://localhost:8188)
# - Local/self-hosted ComfyUI: http://localhost:8188
# - Comfy Cloud: https://cloud.comfy.org
COMFYUI_BASE_URL=http://localhost:8188

# Comfy Cloud API key (required only when COMFYUI_BASE_URL=https://cloud.comfy.org)
# Passed as X-API-Key for Cloud API requests and token auth for Cloud WebSocket progress.
COMFY_CLOUD_API_KEY=

# Timeout in seconds for generation jobs (default: 300)
COMFYUI_TIMEOUT=300

# =============================================================================
# Image Quality Gate Configuration
# =============================================================================
# Enable vision model review of generated images before video generation
# Requires an LLM that supports image inputs (e.g., GPT-4o, Gemini)
LLM_SUPPORTS_VISION=false

# =============================================================================
# Analytics Configuration (PostHog)
# =============================================================================
# Project API key from PostHog project settings (starts with phc_)
POSTHOG_API_KEY=your-posthog-project-api-key

# Optional: Override PostHog ingest host if using EU/self-hosted endpoint.
# Default (when unset): https://us.i.posthog.com
POSTHOG_HOST=https://us.i.posthog.com

# Optional: Salt for hashing project directory paths before sending analytics
ANALYTICS_SALT=replace_with_random_secret
